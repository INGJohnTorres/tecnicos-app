# Cadena de conexión a Postgres (Neon, Supabase, Railway, Render, o local).
# Ejemplo Neon/Supabase: postgresql://usuario:clave@host/nombre_db?sslmode=require
DATABASE_URL="postgresql://usuario:clave@localhost:5432/tecnicos_app"

# Secreto para firmar los tokens de sesión (JWT). Generalo con:
#   openssl rand -base64 32
JWT_SECRET="reemplazar_con_un_secreto_largo_y_aleatorio"

# Claves VAPID para las notificaciones push (Fase 5). Se generan una sola
# vez con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="reemplazar_con_la_clave_publica"
VAPID_PRIVATE_KEY="reemplazar_con_la_clave_privada"

# Secreto para proteger el endpoint de recordatorio diario (Fase 5).
# Generalo igual que el JWT_SECRET. Vercel lo manda automático en el
# header Authorization cuando configurás esta misma variable en su panel.
CRON_SECRET="reemplazar_con_otro_secreto_largo"
